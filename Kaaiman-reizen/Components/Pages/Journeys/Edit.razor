@* @page "/journey/edit/{Id:int}"
@rendermode InteractiveServer
@using Kaaiman_reizen.Data.Entities
@using Kaaiman_reizen.Data.Enums
@using Kaaiman_reizen.Data.Services
@inject IJourneyService JourneyService
@inject NavigationManager Navigation

<PageTitle>Bewerk reis</PageTitle>

<h1 class="h4">Bewerk reis</h1>

<div class="card">
    <div class="card-body">
        @if (_loading)
        {
            <div>Bezig met laden…</div>
        }
        else if (_notFound)
        {
            <div class="text-muted">Reis niet gevonden.</div>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Land</label>
                    <InputText class="form-control" @bind-Value="_model.Country" />
                    <ValidationMessage For="() => _model.Country" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Start datum</label>
                    <InputDate class="form-control" @bind-Value="_model.Start" />
                    <ValidationMessage For="() => _model.Start" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Eind Datum</label>
                    <InputDate class="form-control" @bind-Value="_model.End" />
                    <ValidationMessage For="() => _model.End" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Aantal busjes</label>
                    <InputNumber class="form-control" @bind-Value="_model.Busses" />
                    <ValidationMessage For="() => _model.Busses" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Aantal reizigers</label>
                    <InputNumber class="form-control" @bind-Value="_model.Travelers" />
                    <ValidationMessage For="() => _model.Travelers" />
                </div>

                <h5>Reisleiders</h5>
                @for (int i = 0; i < _preferredPeriods.Count; i++)
                {
                    var period = _preferredPeriods[i];
                    var idx = i;
                    <div class="row mb-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Start</label>
                            <InputDate @bind-Value="period.Start" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Eind</label>
                            <InputDate @bind-Value="period.End" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger" @onclick="() => RemovePeriod(idx)">Verwijder</button>
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="AddPeriod">+ Periode toevoegen</button>
                </div>

                <div class="d-flex">
                    <button type="submit" class="btn btn-primary">Opslaan</button>
                    <span class="ms-2">
                        <Button TItem="object" Type="ButtonType.Secondary" OnClickNoArg="EventCallback.Factory.Create(this, Cancel)">Annuleren</Button>
                    </span>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Journey _model = new();
    private bool _loading = true;
    private bool _notFound = false;
    private List<TravelLeader> _travelLeaders = new();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _notFound = false;

        var item = await JourneyService.GetJourneyByIdAsync(Id);
        if (item == null)
        {
            _notFound = true;
            _loading = false;
            return;
        }

        _model = item;

        // populate travelLeaders
        _travelLeaders.Clear();
        if (_model.TravelLeaders != null)
        {
            foreach (var p in _model.TravelLeaders.OrderBy(p => p.Name))
            {
                _travelLeaders.Add(new PeriodModel { Start = p.Start.ToDateTime(TimeOnly.MinValue), End = p.End.ToDateTime(TimeOnly.MinValue) });
            }
        }

        _loading = false;
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/journeys");
    }

    private async Task HandleValidSubmit()
    {
        // map travel leaders
        _model.TravelLeaders = _travelLeaders
            .Where(t => t.Start.HasValue && ptEnd.HasValue)
            .Select(t => new AvailabilityPeriod { Start = DateOnly.FromDateTime(p.Start!.Value), End = DateOnly.FromDateTime(t.End!.Value) })
            .ToList();

        await JourneyService.UpdateJourneyAsync(_model);
        Navigation.NavigateTo("/journeys");
    }

    private void AddTravelLeader()
    {
        _travelLeaders.Add(new TravelLeader());
    }

    private void removeTravelLeader(int index)
    {
        if (index >= 0 && index < _travelLeaders.Count)
            _travelLeaders.RemoveAt(index);
    }
} *@
