@page "/draft-test"
@rendermode InteractiveServer
@using Kaaiman_reizen.Models
@using Kaaiman_reizen.Models.ViewModels
@using Kaaiman_reizen.Services
@inject IPlannerDraftService DraftService

<MudStack Spacing="4" Class="pa-4">
    <MudText Typo="Typo.h5" GutterBottom="true">Planner Draft Dashboard</MudText>

    @if (_request != null)
    {
        <!-- Planner Status Header -->
        <MudPaper Elevation="1" Class="pa-4 mb-2" Style="@("background-color: var(--mud-palette-background-grey);")">
            <MudGrid>
                <MudItem xs="12" sm="6" Class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Class="mr-3" Color="Color.Primary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Status Planning</MudText>
                        <div class="d-flex align-center mt-1">
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">Concept</MudChip>
                            <MudText Typo="Typo.caption" Color="Color.Error" Class="ml-2">
                                <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mr-1 mb-n1" /> Deadline indienen: 15 Mei 2026
                            </MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-center justify-end">
                    @{
                        // Anyone with at least 1 preference is considered to have "filled it in" for this dummy logic.
                        var completedLeaders = _request.AvailableLeaders.Count(l => l.PreferredDestinations.Any());
                        var totalLeaders = _request.AvailableLeaders.Count;
                        var progressColor = completedLeaders == totalLeaders ? Color.Success : Color.Warning;
                    }
                    <div class="text-right mr-3">
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Reisleiders Compleet</MudText>
                        <MudText Typo="Typo.body1" Class="mb-1"><b>@completedLeaders / @totalLeaders</b> gegevens</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Error">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mr-1 mb-n1" /> Deadline opgave: 1 Mei 2026
                        </MudText>
                    </div>
                    <MudProgressCircular Value="@((double)completedLeaders / totalLeaders * 100)" Color="@progressColor" Size="Size.Medium" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mt-4 mb-1">Pre-Generation Insights</MudText>
        <MudGrid Class="mb-4">
            <!-- Top 3 Most Popular Destinations -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Style="@("border-top: 4px solid var(--mud-palette-success); height: 100%;")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Top 3 Popular</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string" Dense="true">
                            @foreach (var item in _topPopular)
                            {
                                <MudListItem T="string">
                                    <div class="d-flex justify-space-between align-center w-100">
                                        <MudText><b>@item.Country</b></MudText>
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">@item.Count interested</MudChip>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Least Popular Destinations -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Style="@("border-top: 4px solid var(--mud-palette-error); height: 100%;")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Least Popular</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string" Dense="true">
                            @foreach (var item in _leastPopular)
                            {
                                <MudListItem T="string">
                                    <div class="d-flex justify-space-between align-center w-100">
                                        <MudText><b>@item.Country</b></MudText>
                                        <MudChip T="string" Color="Color.Error" Size="Size.Small">@item.Count interested</MudChip>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Leaders with Multiple Interests -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Style="@("border-top: 4px solid var(--mud-palette-info); height: 100%;")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Flexible Leaders</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string" Dense="true">
                            @foreach (var leader in _multiInterestLeaders.Take(4))
                            {
                                <MudListItem T="string">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body1"><b>@leader.Name</b></MudText>
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var pref in leader.PreferredDestinations.OrderBy(p => p.Value))
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                    @pref.Key (#@pref.Value)
                                                </MudChip>
                                            }
                                        </div>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }

    <div>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="GenerateDraftAsync" 
                   Disabled="@_isGenerating">
            @if (_isGenerating)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                <MudText Class="ms-2">Generating Draft...</MudText>
            }
            else
            {
                <MudText>Generate Magic Draft</MudText>
            }
        </MudButton>
    </div>

    @if (_isGenerating)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Please wait, the planner AI is optimizing your schedule...
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" />
        </MudAlert>
    }
    else if (_result != null && _request != null)
    {
        if (_result.IsSuccess)
        {
            var totalMatches = _result.JourneyAssignments.Count;

            <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">Success! Matches found:
            </MudAlert>

            <MudText Typo="Typo.h6" Class="mb-2 mt-2">Assignment Happiness Score</MudText>
            <MudGrid Class="mb-6">
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1"
                              Style="@("border-top: 4px solid var(--mud-palette-success);")">
                        <MudText Typo="Typo.h4"><b>@_result.Rank1Matches</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Keuze #1
                            (@(totalMatches > 0 ? Math.Round((double)_result.Rank1Matches / totalMatches * 100) : 0)%)
                        </MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1"
                              Style="@("border-top: 4px solid var(--mud-palette-info);")">
                        <MudText Typo="Typo.h4"><b>@_result.Rank2Matches</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Keuze #2
                            (@(totalMatches > 0 ? Math.Round((double)_result.Rank2Matches / totalMatches * 100) : 0)%)
                        </MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1"
                              Style="@("border-top: 4px solid var(--mud-palette-warning);")">
                        <MudText Typo="Typo.h4"><b>@_result.Rank3Matches</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Keuze #3
                            (@(totalMatches > 0 ? Math.Round((double)_result.Rank3Matches / totalMatches * 100) : 0)%)
                        </MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1"
                              Style="@("border-top: 4px solid var(--mud-palette-dark);")">
                        <MudText Typo="Typo.h4"><b>@_result.NoPreferenceMatches</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Geen voorkeur
                            (@(totalMatches > 0 ? Math.Round((double)_result.NoPreferenceMatches / totalMatches * 100) : 0)%)
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudStack Spacing="3">
                @foreach (var kvp in _result.JourneyAssignments)
                {
                    var assignment = kvp.Value;
                    var journey = _request.JourneysToPlan.First(j => j.Id == kvp.Key);
                    var leader = _request.AvailableLeaders.First(l => l.Id == assignment.LeaderId);

                    <MudPaper Class="pa-4" Elevation="1" Style="@("border-left: 4px solid var(--mud-palette-primary);")">
                        <MudGrid>
                            <MudItem xs="12" sm="5">
                                <MudText Typo="Typo.h6">@journey.Country</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small"
                                             Class="mr-1 mb-n1"/>
                                    @journey.Start.ToString("dd MMM yyyy") - @journey.End.ToString("dd MMM yyyy")
                                </MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudText Typo="Typo.subtitle1"><b>Assigned Leader:</b> @leader.Name</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.WorkOutline" Size="Size.Small"
                                             Class="mr-1 mb-n1"/>
                                    <b>Experience:</b> @leader.YearsOfExperience years
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1 mb-n1"/>
                                    <b>Availability:</b> @leader.Availability
                                </MudText>
                            </MudItem>
                            <MudItem xs="12" sm="3" Class="d-flex align-center justify-end">
                                @if (assignment.RankMatched.HasValue)
                                {
                                    <MudChip T="string"
                                             Color="@(assignment.RankMatched == 1 ? Color.Success : assignment.RankMatched == 2 ? Color.Info : Color.Warning)"
                                             Size="Size.Small">
                                        Keuze #@assignment.RankMatched
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small">Geen voorkeur</MudChip>
                                }
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }
            </MudStack>


                var assignedIds = _result.JourneyAssignments.Values.Select(v => v.LeaderId).ToHashSet();
                var unassignedLeaders = _request.AvailableLeaders.Where(l => !assignedIds.Contains(l.Id)).ToList();


                if (unassignedLeaders.Any())
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mt-6 mb-4">
                        Unassigned Leaders (@unassignedLeaders.Count)
                    </MudAlert>

                    <MudGrid>
                        @foreach (var leader in unassignedLeaders)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudPaper Class="pa-4" Elevation="1"
                                          Style="@("border-left: 4px solid var(--mud-palette-warning);")">
                                    <MudText Typo="Typo.subtitle1"><b>@leader.Name</b></MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.WorkOutline" Size="Size.Small"
                                                 Class="mr-1 mb-n1"/>
                                        <b>Experience:</b> @leader.YearsOfExperience years
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                                                 Class="mr-1 mb-n1"/>
                                        <b>Availability:</b> @leader.Availability
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }
        }
        else
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                <b>Draft Generation Failed:</b> @_result.ErrorMessage
            </MudAlert>
        }
    }
</MudStack>

@code {
    private PlannerDraftResult? _result;
    private PlannerDraftRequest? _request;
    private bool _isGenerating = false;

    private List<(string Country, int Count)> _topPopular = new();
    private List<(string Country, int Count)> _leastPopular = new();
    private List<TravelLeaderViewModel> _multiInterestLeaders = new();

    protected override void OnInitialized()
    {
        var fakeLeaders = new List<TravelLeaderViewModel>
        {
            new TravelLeaderViewModel { Id = 101, Name = "Alice Smith", YearsOfExperience = 5, Availability = "01 Jun - 31 Aug", PreferredDestinations = new() { { "Norway", 1 }, { "Sweden", 2 } } }, 
            new TravelLeaderViewModel { Id = 102, Name = "Bob Jones", YearsOfExperience = 2, Availability = "15 Jun - 30 Sep", PreferredDestinations = new() { { "Finland", 1 }, { "Sweden", 2 }, { "Norway", 3 } } },
            new TravelLeaderViewModel { Id = 103, Name = "Charlie Brown", YearsOfExperience = 8, Availability = "10 Jul - 31 Oct", PreferredDestinations = new() { { "Sweden", 1 } } },
            new TravelLeaderViewModel { Id = 104, Name = "Diana Prince", YearsOfExperience = 12, Availability = "01 Jun - 15 Jul", PreferredDestinations = new() { { "Italy", 1 }, { "Greece", 2 }, { "France", 3 } } },
            new TravelLeaderViewModel { Id = 105, Name = "Eve Adams", YearsOfExperience = 1, Availability = "Jul - Sep", PreferredDestinations = new() { { "France", 1 }, { "Switzerland", 2 } } },
            new TravelLeaderViewModel { Id = 106, Name = "Frank Castle", YearsOfExperience = 4, Availability = "All Summer", PreferredDestinations = new() { { "Denmark", 1 }, { "Iceland", 2 } } },
            new TravelLeaderViewModel { Id = 107, Name = "George Clark", YearsOfExperience = 7, Availability = "Jun - Aug", PreferredDestinations = new() { { "Germany", 1 }, { "Austria", 2 }, { "Switzerland", 3 } } },
            new TravelLeaderViewModel { Id = 108, Name = "Hannah Montana", YearsOfExperience = 0, Availability = "Jul - Oct", PreferredDestinations = new() { { "Spain", 1 }, { "Portugal", 2 } } },
            new TravelLeaderViewModel { Id = 109, Name = "Ian McKellen", YearsOfExperience = 15, Availability = "Jul - Aug", PreferredDestinations = new() { { "Slovenia", 1 }, { "Croatia", 2 } } },
            new TravelLeaderViewModel { Id = 110, Name = "Jenny Lopez", YearsOfExperience = 3, Availability = "Jun - Sep", PreferredDestinations = new() { { "Italy", 1 }, { "France", 2 }, { "Greece", 3 } } },
            new TravelLeaderViewModel { Id = 111, Name = "Kevin Bacon", YearsOfExperience = 6, Availability = "Jun - Aug", PreferredDestinations = new() { { "Iceland", 1 }, { "Norway", 2 } } },
            new TravelLeaderViewModel { Id = 112, Name = "Laura Croft", YearsOfExperience = 10, Availability = "Aug - Oct", PreferredDestinations = new() { { "Spain", 1 }, { "Portugal", 2 } } },
            new TravelLeaderViewModel { Id = 113, Name = "Mike Tyson", YearsOfExperience = 2, Availability = "Jun - Jul", PreferredDestinations = new() { { "Austria", 1 }, { "Germany", 2 } } },
            new TravelLeaderViewModel { Id = 114, Name = "Nina Simone", YearsOfExperience = 9, Availability = "Jul - Sep", PreferredDestinations = new() { { "France", 1 }, { "Italy", 2 }, { "Spain", 3 } } },
            new TravelLeaderViewModel { Id = 115, Name = "Oscar Wilde", YearsOfExperience = 1, Availability = "Aug - Oct", PreferredDestinations = new() { { "Greece", 1 } } },
            new TravelLeaderViewModel { Id = 116, Name = "Peter Parker", YearsOfExperience = 4, Availability = "Jun - Sep", PreferredDestinations = new() { { "Norway", 1 }, { "Finland", 2 } } },
            new TravelLeaderViewModel { Id = 117, Name = "Quinn Fabray", YearsOfExperience = 0, Availability = "All Summer", PreferredDestinations = new() { { "Sweden", 1 }, { "Denmark", 2 } } },
            // Missing Info
            new TravelLeaderViewModel { Id = 118, Name = "Tom Holland", YearsOfExperience = 2, Availability = "-", PreferredDestinations = new() },
            new TravelLeaderViewModel { Id = 119, Name = "Zendaya", YearsOfExperience = 3, Availability = "-", PreferredDestinations = new() }
        };

        var fakeJourneys = new List<JourneyViewModel>
        {
            new JourneyViewModel { Id = 10, Country = "Norway", Start = new DateTime(2026, 6, 1), End = new DateTime(2026, 6, 14) },
            new JourneyViewModel { Id = 20, Country = "Sweden", Start = new DateTime(2026, 7, 10), End = new DateTime(2026, 7, 24) },
            new JourneyViewModel { Id = 30, Country = "Finland", Start = new DateTime(2026, 8, 5), End = new DateTime(2026, 8, 19) },
            new JourneyViewModel { Id = 40, Country = "Italy", Start = new DateTime(2026, 6, 15), End = new DateTime(2026, 6, 28) },
            new JourneyViewModel { Id = 50, Country = "France", Start = new DateTime(2026, 7, 1), End = new DateTime(2026, 7, 15) },
            new JourneyViewModel { Id = 60, Country = "Greece", Start = new DateTime(2026, 8, 1), End = new DateTime(2026, 8, 14) },
            new JourneyViewModel { Id = 70, Country = "Spain", Start = new DateTime(2026, 7, 20), End = new DateTime(2026, 8, 2) },
            new JourneyViewModel { Id = 80, Country = "Portugal", Start = new DateTime(2026, 8, 15), End = new DateTime(2026, 8, 28) },
            new JourneyViewModel { Id = 90, Country = "Switzerland", Start = new DateTime(2026, 6, 20), End = new DateTime(2026, 7, 4) },
            new JourneyViewModel { Id = 100, Country = "Austria", Start = new DateTime(2026, 7, 5), End = new DateTime(2026, 7, 18) },
            new JourneyViewModel { Id = 110, Country = "Germany", Start = new DateTime(2026, 8, 10), End = new DateTime(2026, 8, 23) },
            new JourneyViewModel { Id = 120, Country = "Denmark", Start = new DateTime(2026, 6, 5), End = new DateTime(2026, 6, 18) },
            new JourneyViewModel { Id = 130, Country = "Iceland", Start = new DateTime(2026, 7, 25), End = new DateTime(2026, 8, 7) },
            new JourneyViewModel { Id = 140, Country = "Croatia", Start = new DateTime(2026, 8, 20), End = new DateTime(2026, 9, 2) },
            new JourneyViewModel { Id = 150, Country = "Slovenia", Start = new DateTime(2026, 7, 15), End = new DateTime(2026, 7, 28) },
            new JourneyViewModel { Id = 160, Country = "Norway", Start = new DateTime(2026, 7, 1), End = new DateTime(2026, 7, 14) },
            new JourneyViewModel { Id = 170, Country = "Sweden", Start = new DateTime(2026, 8, 1), End = new DateTime(2026, 8, 14) }
        };

        _request = new PlannerDraftRequest
        {
            AvailableLeaders = fakeLeaders,
            JourneysToPlan = fakeJourneys
        };

        // Calculate statistics
        var popularity = fakeJourneys
            .Select(j => j.Country)
            .Distinct()
            .Select(c => (Country: c, Count: fakeLeaders.Count(l => l.PreferredDestinations.ContainsKey(c))))
            .ToList();

        _topPopular = popularity.OrderByDescending(p => p.Count).Take(3).ToList();
        
        // Least popular, but prefer countries that still have 0 or 1.
        _leastPopular = popularity.OrderBy(p => p.Count).Take(3).ToList();
        
        _multiInterestLeaders = fakeLeaders
            .Where(l => l.PreferredDestinations.Count > 1)
            .OrderByDescending(l => l.PreferredDestinations.Count)
            .ToList();
    }

    private async Task GenerateDraftAsync()
    {
        if (_request == null) return;

        _isGenerating = true;
        _result = null; 
        
        StateHasChanged(); 
        await Task.Delay(50); 
        
        Console.WriteLine($"Sending {_request.JourneysToPlan.Count} journeys and {_request.AvailableLeaders.Count} leaders to OR-Tools...");
        _result = await Task.Run(() => DraftService.GenerateDraft(_request));
        
        Console.WriteLine($"OR-Tools generation completed! Success: {_result.IsSuccess}. Matches Found: {_result.JourneyAssignments.Count}");
        
        _isGenerating = false;
    }
}
