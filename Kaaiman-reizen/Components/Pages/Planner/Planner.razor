@page "/planner"
@rendermode InteractiveServer
@using Microsoft.Extensions.Hosting
@using Microsoft.Extensions.Logging
@using Kaaiman_reizen.Data.Services
@using Kaaiman_reizen.Extensions
@using Kaaiman_reizen.Helpers
@using Kaaiman_reizen.Models.ViewModels
@inject ITravelLeaderService LeaderService
@inject ILogger<Planner> Logger
@inject IHostEnvironment HostEnvironment

<PageTitle>Planner</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h5">Planner</MudText>

    <MudGrid Spacing="2">
        <MudItem xs="12" md="8">
            <MudPaper Elevation="1" Class="pa-6 d-flex align-center justify-center" Style="min-height: 420px; background-color: #f3f4f6;">
                <MudText Typo="Typo.h6" Color="Color.Secondary">here we will place planner view</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="1" Class="pa-4" Style="min-height: 420px;">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                    <MudText Typo="Typo.h6">Reisleiders</MudText>
                    <MudChip T="int" Size="Size.Small" Variant="Variant.Outlined">@_leaders.Count</MudChip>
                </MudStack>

                <DataLoader TItem="TravelLeaderViewModel" Items="@_leaders" IsLoading="@_loading" Error="@_error" EmptyMessage="Geen reisleiders gevonden.">
                    <ChildContent Context="leaders">
                        <TravelLeaderList Leaders="leaders" />
                    </ChildContent>
                </DataLoader>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private bool _loading = true;
    private string? _error;
    private List<TravelLeaderViewModel> _leaders = [];

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var items = await LeaderService.GetTravelLeadersAsync();
            _leaders = items.ToViewModels().ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Kon reisleiders niet laden (planner)");
            _error = $"Kon reisleiders niet laden: {LoadErrorFormatter.Format(ex, HostEnvironment)}";
            _leaders = [];
        }
        finally
        {
            _loading = false;
        }
    }
}

