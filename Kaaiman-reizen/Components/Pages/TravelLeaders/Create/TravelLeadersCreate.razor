@page "/travelleaders/create"
@rendermode InteractiveServer
@using Kaaiman_reizen.Data.Entities
@using Kaaiman_reizen.Data.Services


<PageTitle>Nieuwe reisleider</PageTitle>

<h1 class="h4">Nieuwe reisleider</h1>

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Naam</label>
                <InputText class="form-control" @bind-Value="_model.Name" />
                <ValidationMessage For="() => _model.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Telefoon</label>
                <InputText class="form-control" @bind-Value="_model.PhoneNumber" />
                <ValidationMessage For="() => _model.PhoneNumber" />
            </div>

            <div class="mb-3">
                <label class="form-label">Aantal reizen</label>
                <InputNumber class="form-control" @bind-Value="_model.AmountOfTrips" />
                <ValidationMessage For="() => _model.AmountOfTrips" />
            </div>

            <div class="mb-3">
                <label class="form-label">Minimaal aantal reizen per jaar</label>
                <InputNumber class="form-control" @bind-Value="_model.MinTrips" />
                <ValidationMessage For="() => _model.MinTrips" />
            </div>

            <div class="mb-3">
                <label class="form-label">Maximaal aantal reizen per jaar</label>
                <InputNumber class="form-control" @bind-Value="_model.MaxTrips" />
                <ValidationMessage For="() => _model.MaxTrips" />
            </div>

            <div class="mb-3">
                <label class="form-label">Notitie</label>
                <InputTextArea class="form-control" @bind-Value="_model.Note" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="_model.IsActive" />
                <label class="form-check-label">Actief</label>
            </div>

            <h5>Beschikbaarheid (periode)</h5>
            @for (int i = 0; i < _periods.Count; i++)
            {
                var period = _periods[i];
                var idx = i;
                <div class="row mb-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Start</label>
                        <InputDate @bind-Value="period.Start" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Eind</label>
                        <InputDate @bind-Value="period.End" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="@(EventCallback.Factory.Create(this, () => RemovePeriod(idx)))">
                            Verwijder
                        </MudButton>
                    </div>
                </div>
            }

            <div class="mb-3">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddPeriod">
                    Periode toevoegen
                </MudButton>
            </div>

            <div class="d-flex">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save">
                    Opslaan
                </MudButton>
                <span class="ms-2">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="Cancel">
                        Annuleren
                    </MudButton>
                </span>
            </div>
        </EditForm>
    </div>
</div>


