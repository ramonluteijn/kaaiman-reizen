@page "/travelleaders"
@rendermode InteractiveServer
@using Kaaiman_reizen.Data.Services
@using Kaaiman_reizen.Data.Entities
@inject ITravelLeaderService LeaderService
@inject IJSRuntime JS

<PageTitle>Reisleiders</PageTitle>

<h1 class="h4">Reisleiders</h1>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-end mb-3">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/travelleaders/create">
                Nieuwe reisleider
            </MudButton>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Telefoon</th>
                    <th>Aantal reizen</th>
                    <th>Beschikbaar</th>
                    <th>Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var leader in _leaders)
                {
                    <tr>
                        <td>@leader.Name</td>
                        <td>@leader.PhoneNumber</td>
                        <td>@leader.AmountOfTrips</td>
                        <td>
                            @if (leader.AvailabilityPeriods != null && leader.AvailabilityPeriods.Any())
                            {
                                @FormatAvailability(leader)
                            }
                        </td>
                        <td>
                            <MudStack Row Spacing="1" Justify="Justify.FlexEnd">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Primary"
                                               Href="@($"/travelleaders/edit/{leader.Id}")"
                                               AriaLabel="Bewerk" />

                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(EventCallback.Factory.Create(this, () => OnDelete(leader)))"
                                               AriaLabel="Verwijderen" />
                            </MudStack>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_leaders.Count == 0)
        {
            <div class="text-muted">Geen reisleiders gevonden.</div>
        }
    </div>
</div>

@code {
    private List<TravelLeader> _leaders = new();

    private string FormatAvailability(TravelLeader leader)
    {
        var periods = leader.AvailabilityPeriods ?? new List<AvailabilityPeriod>();
        return string.Join("; ", periods.OrderBy(p => p.Start)
            .Select(p => $"{p.Start:dd MMM} – {p.End:dd MMM}"));
    }

    private async Task OnDelete(TravelLeader? leader)
    {
        if (leader == null)
            return;

        //TODO: Make a cool custom confirmation dialog
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Weet je zeker dat je '{leader.Name}' wilt verwijderen?");
        if (!confirm)
            return;

        await LeaderService.DeleteTravelLeaderAsync(leader.Id);
        _leaders.RemoveAll(l => l.Id == leader.Id);
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await LeaderService.GetTravelLeadersAsync();
            _leaders = items.ToList();
        }
        catch
        {
            _leaders = new List<TravelLeader>();
        }
    }
}
