@page "/travelleaders"
@rendermode InteractiveServer
@using Kaaiman_reizen.Models.ViewModels

<PageTitle>Reisleiders</PageTitle>

<h1 class="h4">Reisleiders</h1>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-end mb-3">
            <MudButton Href="/travelleaders/create"
                       Variant="Variant.Filled"
                       Color="Color.Success">
                Nieuwe reisleider
            </MudButton>
        </div>
        <DataLoader TItem="TravelLeaderViewModel" Items="@_leaders" IsLoading="@_loading" Error="@_error" EmptyMessage="Geen reisleiders gevonden.">
            <ChildContent Context="leaders">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Telefoon</th>
                            <th>Reizen ervaring</th>
                            <th>Min aantal reizen</th>
                            <th>Max aantal reizen</th>
                            <th>Beschikbaar</th>
                            <th>Actief</th>
                            <th>Acties</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var leader in leaders)
                        {
                            <tr>
                                <td>@leader.Name</td>
                                <td>@leader.PhoneNumber</td>
                                <td>@leader.AmountOfTrips</td>
                                <td>@leader.MinTrips</td>
                                <td>@leader.MaxTrips</td>
                                <td>@leader.Availability</td>
                                <td>
                                    <span class="badge @(leader.IsActive ? "bg-success" : "bg-danger")">
                                        @(leader.IsActive ? "Ja" : "Nee")
                                    </span>
                                </td>
                                <td>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Color="Color.Secondary"
                                                   Href="@($"/travelleaders/edit/{leader.Id}")"
                                                   title="Bewerk"
                                                   aria-label="Bewerk" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   title="Verwijderen"
                                                   aria-label="Verwijderen"
                                                   OnClick="@(() => OnDelete(leader))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </ChildContent>
        </DataLoader>
    </div>
</div>
