@page "/travelleaders"
@rendermode InteractiveServer
@using Kaaiman_reizen.Models.ViewModels
@using Kaaiman_reizen.Data.Services
@using Kaaiman_reizen.Data.Entities
@inject IJSRuntime JS

<PageTitle>Reisleiders</PageTitle>

<h1 class="h4">Reisleiders</h1>

<div class="card">
    <div class="card-body">
        <Table TItem="TravelLeaderViewModel" Items="_leaders" OnDelete="@OnDelete" Path="travelleaders" CreateText="Nieuwe reisleider" EditHrefSelector="@GetEditHref">
            <HeaderContent>
                <th>Naam</th>
                <th>Telefoon</th>
                <th>Reizen ervaring</th>
                <th>Min aantal reizen</th>
                <th>Max aantal reizen</th>
                <th>Beschikbaar</th>
                <th>Actief</th>
            </HeaderContent>
            <RowTemplate>
                <td>@context.Name</td>
                <td>@context.PhoneNumber</td>
                <td>@context.AmountOfTrips</td>
                <td>@context.MinTrips</td>
                <td>@context.MaxTrips</td>
                <td>
                    @context.Availability
                </td>
                <td>
                    <span class="badge @(context.IsActive ? "bg-success" : "bg-danger")" style="cursor: pointer;" @onclick="@(() => ToggleActive(context))">
                        @(context.IsActive ? "Ja" : "Nee")
                    </span>
                </td>
            </RowTemplate>
        </Table>

        @if (_leaders.Count == 0)
        {
            <div class="text-muted">Geen reisleiders gevonden.</div>
        }
    </div>
</div>

