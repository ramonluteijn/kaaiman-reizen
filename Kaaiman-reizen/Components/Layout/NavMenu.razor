@using Microsoft.AspNetCore.Components.Authorization

<div class="d-flex justify-content-center py-4 border-b mud-border-lines-default">
    <a href="/">
        <img src="images/Kaaiman-reizen-logo.webp" class="img-fluid" style="max-height: 50px;" alt="Logo Kaaiman-reizen" />
    </a>
</div>

<MudNavMenu Margin="Margin.Normal">
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

    <AuthorizeView>
        <NotAuthorized>
            <MudNavLink Href="Identity/Account/Login" Icon="@Icons.Material.Filled.Login">Inloggen</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>

    <AuthorizeView Roles="Planner">
        <Authorized>
            <MudNavLink Href="travelleaders" Icon="@Icons.Material.Filled.People">Reisleiders</MudNavLink>
            <MudNavLink Href="journeys" Icon="@Icons.Material.Filled.AirplanemodeActive">Reizen</MudNavLink>
            <MudNavLink Href="planner" Icon="@Icons.Material.Filled.CalendarMonth">Planner</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <div class="px-4 py-3 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Success" Class="mr-3" />
                <MudText Typo="Typo.body2" Class="text-muted text-truncate">@context.User.Identity?.Name</MudText>
            </div>
            
            <form action="Identity/Account/Logout" method="post" class="mt-1 w-100">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="" />
                <button type="submit" class="w-100 bg-transparent border-0 d-flex align-center px-4 py-3 text-start mud-nav-link" style="cursor: pointer; outline: none; box-shadow: none; color: var(--mud-palette-action-default);">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-3" />
                    <MudText Typo="Typo.body2" Class="mud-nav-link-text">Uitloggen</MudText>
                </button>
            </form>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>