<MudButton Variant="Variant.Filled"
           Color="@GetMudColor()"
           Href="@Href"
           OnClick="@HandleClick"
           ButtonType="@GetMudButtonType()">
    @ChildContent
</MudButton>

@code {
    [Parameter] public string? Href { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback HandleClick { get; set; }
    [Parameter] public string? Type { get; set; }

    private Color GetMudColor() => Type?.ToLower() switch
    {
        "primary" => Color.Primary,
        "secondary" => Color.Secondary,
        "danger" => Color.Error,
        "success" => Color.Success,
        _ => Color.Default
    };

    private MudBlazor.ButtonType GetMudButtonType() =>
        Type == "submit" ? MudBlazor.ButtonType.Submit : MudBlazor.ButtonType.Button;
}