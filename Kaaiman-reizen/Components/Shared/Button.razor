@typeparam TItem

@if (!HasHref)
{
    <button type="button" class="btn @GetButtonClass()" @onclick="HandleClick">
        @ChildContent
    </button>
}
else
{
    @if (OnClick.HasDelegate)
    {
        <a class="@GetCssClass()" href="@Href" @onclick="HandleClick" @onclick:preventDefault="true">
            @ChildContent
        </a>
    }
    else
    {
        <a class="@GetCssClass()" href="@Href">
            @ChildContent
        </a>
    }
}

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback<TItem?> OnClick { get; set; }

    [Parameter]
    public EventCallback OnClickNoArg { get; set; }
    
    [Parameter]
    public TItem? Item { get; set; }

    [Parameter]
    public string Class { get; set; } = string.Empty;
    
    [Parameter]
    public bool IsButton { get; set; } = true;

    [Parameter]
    public string? Href { get; set; }
    
    private bool HasHref => !string.IsNullOrWhiteSpace(Href);
    
    private string GetButtonClass()
    {
        var extra = string.IsNullOrWhiteSpace(Class) ? "" : $" {Class}";
        return $"btn btn-primary{extra}";
    }

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(Item);
            return;
        }

        if (OnClickNoArg.HasDelegate)
        {
            await OnClickNoArg.InvokeAsync();
            return;
        }

        if (HasHref)
        {
            var isAbsolute = Uri.IsWellFormedUriString(Href, UriKind.Absolute);
            NavigationManager.NavigateTo(Href!, forceLoad: isAbsolute);
        }
    }
}
