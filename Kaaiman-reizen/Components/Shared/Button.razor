@using Kaaiman_reizen.Data.Enums
@typeparam TItem

@if (IsButton)
{

    <button class="btn @GetButtonClass()" @onclick="HandleClick">
        @ChildContent
    </button>
}
else
{
    @if (OnClick.HasDelegate)
    {
        <a class="btn @GetButtonClass()" href="@Href" @onclick="HandleClick" @onclick:preventDefault="true">
            @ChildContent
        </a>
    }
    else
    {
        <a class="btn @GetButtonClass()" href="@Href">
            @ChildContent
        </a>
    }
}

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback<TItem?> OnClick { get; set; }

    [Parameter]
    public EventCallback OnClickNoArg { get; set; }
    
    [Parameter]
    public TItem? Item { get; set; }
    
    [Parameter]
    public Kaaiman_reizen.Data.Enums.ButtonType Type { get; set; } = Kaaiman_reizen.Data.Enums.ButtonType.Primary;
    
    [Parameter]
    public bool IsButton { get; set; } = true;
    
    [Parameter]
    public string Href { get; set; } = "#";
    
    private string GetButtonClass()
    {
        return Type switch
        {
            Kaaiman_reizen.Data.Enums.ButtonType.Secondary => "btn-secondary",
            Kaaiman_reizen.Data.Enums.ButtonType.Success => "btn-success",
            Kaaiman_reizen.Data.Enums.ButtonType.Danger => "btn-danger",
            Kaaiman_reizen.Data.Enums.ButtonType.Warning => "btn-warning",
            Kaaiman_reizen.Data.Enums.ButtonType.Info => "btn-info",
            Kaaiman_reizen.Data.Enums.ButtonType.Light => "btn-light",
            Kaaiman_reizen.Data.Enums.ButtonType.Dark => "btn-dark",
            _ => "btn-primary",
        };
    }

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(Item);
            return;
        }

        if (OnClickNoArg.HasDelegate)
        {
            await OnClickNoArg.InvokeAsync();
            return;
        }

        if (!IsButton)
        {
            var isAbsolute = Uri.IsWellFormedUriString(Href, UriKind.Absolute);
            NavigationManager.NavigateTo(Href, forceLoad: isAbsolute);
        }
    }
}
