@typeparam TItem

@if (CreateText != null && CreatePath != null)
{
    <div class="d-flex justify-content-end mb-3">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Href="@CreatePath"
                   StartIcon="@Icons.Material.Filled.Add">
            @CreateText
        </MudButton>
    </div>
}
<table class="table">
    <thead>
    <tr>
        @if (HeaderContent != null)
        {
            @HeaderContent
        }
        else
        {
            <th>Item</th>
        }

        @if (HasActions)
        {
            <th>Acties</th>
        }
    </tr>
    </thead>
    <tbody>
    @if (Items != null)
    {
        foreach (var item in Items)
        {
            <tr>
                @if (RowTemplate != null)
                {
                    @RowTemplate(item)
                }
                else
                {
                    <td>@item</td>
                }

                @if (HasActions)
                    {
                        <td>
                            @if (EditHrefSelector != null)
                            {
                                <span class="me-2">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Href="@EditHrefSelector(item)"
                                                   Title="Bewerk" />
                                </span>
                            }
                            @if (OnDelete.HasDelegate)
                            {
                                <span>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => OnDelete.InvokeAsync(item))"
                                                   Title="Verwijder" />
                                </span>
                            }
                        </td>
                    }
            </tr>
        }
    }
    </tbody>
</table>

@code {
    [Parameter]
    public IEnumerable<TItem>? Items { get; set; }

    [Parameter]
    public RenderFragment? HeaderContent { get; set; }

    [Parameter]
    public RenderFragment<TItem>? RowTemplate { get; set; }
    
    [Parameter]
    public Func<TItem, string?>? EditHrefSelector { get; set; }

    [Parameter]
    public EventCallback<TItem?> OnDelete { get; set; }

    [Parameter]
    public string? CreateText { get; set; }

    [Parameter]
    public string? Path { get; set; }

    private bool HasActions => EditHrefSelector != null || OnDelete.HasDelegate;

    private string? CreatePath => !string.IsNullOrWhiteSpace(Path) ? $"/{Path}/create" : null;
}
